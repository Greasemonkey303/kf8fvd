## Example environment variables for Playwright E2E (staging)
SITE_URL=https://staging.example.com
CF_TURNSTILE_SITEKEY=your-staging-turnstile-sitekey
CF_TURNSTILE_SECRET=your-staging-turnstile-secret
NEXTAUTH_SECRET=replace-with-nextauth-secret
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
REDIS_URL=redis://:password@redis.example.com:6379

# Test accounts used by the E2E tests
TEST_ACCOUNT_EMAIL=testuser@example.com
TEST_ACCOUNT_PASSWORD=Password123!
ADMIN_ACCOUNT_EMAIL=admin@example.com
ADMIN_ACCOUNT_PASSWORD=AdminPassword!
