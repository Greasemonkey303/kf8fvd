# Docker-aware overrides for the app container reaching host services.
DOCKER_DB_HOST=host.docker.internal
DOCKER_DB_PORT=3306
DOCKER_REDIS_HOST=host.docker.internal
DOCKER_REDIS_PORT=6379
DOCKER_REDIS_URL=redis://host.docker.internal:6379
DOCKER_MINIO_HOST=host.docker.internal
DOCKER_MINIO_PORT=9000

# Umami PostgreSQL container.
UMAMI_POSTGRES_DB=umami
UMAMI_POSTGRES_USER=umami
UMAMI_POSTGRES_PASSWORD=replace-with-a-url-safe-password

# Umami application.
UMAMI_APP_SECRET=replace-with-a-long-random-secret
UMAMI_TRACKER_SCRIPT_NAME=script.js
UMAMI_CLIENT_IP_HEADER=x-forwarded-for

# Public frontend tracker configuration.
NEXT_PUBLIC_UMAMI_HOST_URL=http://localhost:3001
NEXT_PUBLIC_UMAMI_SCRIPT_URL=http://localhost:3001/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=replace-with-your-umami-website-id
NEXT_PUBLIC_UMAMI_DOMAINS=kf8fvd.com,www.kf8fvd.com